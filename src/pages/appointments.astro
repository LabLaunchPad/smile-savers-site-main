---
/**
 * Appointments Page — enhanced help section
 */
import PageLayout from "../layouts/PageLayout.astro";
import PageHeader from "../components/common/PageHeader.astro";
import BookingWizard from "../modules/appointments/components/BookingWizard.astro";
import { siteConfig } from "@/config/site";

const title = "Book an Appointment";
const description = "Schedule your dental visit in a few simple steps. We'll confirm within 24 hours.";
---

<PageLayout title={title} description={description}>
  <main id="main-content">
    <PageHeader
      title="Book an Appointment"
      description="Schedule your visit in just a few steps. We confirm every appointment within 24 hours."
      breadcrumbs={[{ label:"Home", href:"/" }, { label:"Appointments" }]}
      badge="Accepting New Patients"
    />

    <section class="bk-section section" aria-label="Booking wizard">
      <div class="bk-container">
        <BookingWizard />
      </div>
    </section>

    <!-- Help cards -->
    <section class="help-section" aria-label="Booking help">
      <div class="help-wrap">

        <div class="help-card help-card--call">
          <div class="hc-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <div>
            <h3 class="hc-title">Prefer to Call?</h3>
            <p class="hc-text">Our team is ready to book you in directly.</p>
            <a href="tel:+17189568400" class="hc-phone">(718) 956-8400</a>
          </div>
        </div>

        <div class="help-card help-card--hours">
          <div class="hc-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <div>
            <h3 class="hc-title">Office Hours</h3>
            <ul class="hc-hours">
              {
                siteConfig.hours.map((h) => {
                  const daysLabel = h.days.length > 1
                    ? `${h.days[0].slice(0, 3)} – ${h.days[h.days.length - 1].slice(0, 3)}`
                    : h.days[0];
                  const isClosed = h.open === 'Closed';
                  const isSaturday = (h.days as readonly string[]).includes('Saturday');
                  return (
                    <li class={`${isSaturday ? 'hc-hours-highlight' : ''} ${isClosed ? 'hc-hours-muted' : ''}`}>
                      <span>{daysLabel}</span>
                      <span>{h.display}</span>
                    </li>
                  );
                })
              }
            </ul>
          </div>
        </div>

        <div class="help-card help-card--emergency">
          <div class="hc-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </div>
          <div>
            <h3 class="hc-title">Dental Emergency?</h3>
            <p class="hc-text">Same-day slots available for urgent dental pain, trauma, or broken teeth.</p>
            <a href="/contact" class="hc-emg-link">Contact for Emergency Care →</a>
          </div>
        </div>

      </div>
    </section>
  </main>
</PageLayout>

<style>
.bk-section { background: var(--color-surface) }
.bk-container { max-width: 820px; margin-inline: auto; padding-inline: clamp(.75rem,3vw,var(--spacing-element)) }

.help-section {
  background: var(--color-surface-sunken);
  padding: clamp(2.5rem,5vw,5rem) 0;
}
.help-wrap {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.125rem;
  max-width: var(--container-xl);
  margin-inline: auto;
  padding-inline: clamp(.75rem,3vw,var(--spacing-element));
}
@media(min-width:640px){ .help-wrap { grid-template-columns: repeat(2,1fr) } }
@media(min-width:1024px){ .help-wrap { grid-template-columns: repeat(3,1fr) } }

.help-card {
  display: flex; gap: 1.125rem;
  padding: 1.5rem; border-radius: 1.125rem;
  background: #fff; border: 1.5px solid var(--color-border);
  transition: all .3s ease;
}
.help-card:hover { box-shadow: 0 8px 28px rgba(16,43,63,.09); transform: translateY(-2px) }

.hc-icon {
  width: 2.75rem; height: 2.75rem; border-radius: .75rem;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.help-card--call .hc-icon { background: #E0F5FF; color: #2CABDF }
.help-card--hours .hc-icon { background: #E8F5E9; color: #10B981 }
.help-card--emergency .hc-icon { background: #FEF2F2; color: #EF4444 }
.help-card--emergency { border-color: #FECACA }

.hc-title { font-size: var(--font-size-base); font-weight: 700; color: var(--color-primary); margin: 0 0 .375rem }
.hc-text { font-size: var(--font-size-sm); color: var(--color-text-muted); line-height: 1.6; margin: 0 0 .75rem }
.hc-phone {
  display: inline-block; font-size: var(--font-size-xl); font-weight: 800;
  color: var(--color-primary); text-decoration: none; letter-spacing: -.01em;
  font-family: var(--font-family-heading);
}
.hc-phone:hover { color: var(--color-secondary-dark) }

.hc-hours { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: .35rem }
.hc-hours li { display: flex; justify-content: space-between; font-size: var(--font-size-sm) }
.hc-hours li span:first-child { color: var(--color-text-muted) }
.hc-hours li span:last-child { font-weight: 600; color: var(--color-text) }
.hc-hours-highlight span { color: var(--color-secondary-dark) !important; font-weight: 700 !important }
.hc-hours-muted span { opacity: .45 }

.hc-emg-link { font-size: var(--font-size-sm); font-weight: 700; color: #EF4444; text-decoration: none }
.hc-emg-link:hover { text-decoration: underline; text-underline-offset: 3px }
@media(prefers-reduced-motion:reduce){ .help-card { transition: none; transform: none } }
</style>
