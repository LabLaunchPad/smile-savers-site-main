---
/**
 * OfficeHours — Enhanced · today highlighted · open/closed status · clean table
 */
import { siteConfig } from '@/config/site';

const hours = siteConfig.businessHours;

const today = new Date().toLocaleDateString('en-US', { weekday: 'long' });
const todayRow = hours.find((h) => h.day === today);
const isOpenToday = todayRow?.open !== null;
---

<div class="oh">
  <div class="oh-header">
    <div>
      <h3 class="oh-title">Office Hours</h3>
      <p class="oh-sub">Walk-ins welcome during open hours</p>
    </div>
    <div class={`oh-status ${isOpenToday ? 'oh-status--open' : 'oh-status--closed'}`}>
      <span class="oh-dot" aria-hidden="true"></span>
      {isOpenToday ? 'Open Today' : 'Closed Today'}
    </div>
  </div>

  <ul class="oh-list">
    {
      hours.map((h) => {
        const isToday = h.day === today;
        const isClosed = h.open === null;
        return (
          <li
            class={`oh-row ${isToday ? 'oh-row--today' : ''} ${isClosed ? 'oh-row--closed' : ''}`}
          >
            <span class="oh-day">
              {h.day}
              {isToday && <span class="oh-today-tag">Today</span>}
            </span>
            <span class="oh-time">{isClosed ? 'Closed' : `${h.open} – ${h.close}`}</span>
          </li>
        );
      })
    }
  </ul>

  <p class="oh-note">
    <svg
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      aria-hidden="true"
      ><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line
        x1="12"
        y1="16"
        x2="12.01"
        y2="16"></line></svg
    >
    Dental emergencies: call <a href="tel:+17189568400">(718) 956-8400</a> any time
  </p>
</div>

<style>
  @keyframes dot-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.35;
    }
  }
  .oh {
    padding: 2rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .oh-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }
  .oh-title {
    font-size: var(--font-size-2xl);
    font-family: var(--font-family-heading);
    font-weight: 700;
    color: var(--color-primary);
    margin: 0 0 0.25rem;
  }
  .oh-sub {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin: 0;
  }
  .oh-status {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.3rem 0.75rem;
    border-radius: 9999px;
    flex-shrink: 0;
  }
  .oh-status--open {
    background: #e8f5e9;
    color: #2e7d32;
  }
  .oh-status--closed {
    background: #fef2f2;
    color: #c62828;
  }
  .oh-dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    flex-shrink: 0;
    animation: dot-pulse 2s ease-in-out infinite;
  }
  .oh-status--open .oh-dot {
    background: #4caf50;
  }
  .oh-status--closed .oh-dot {
    background: #ef4444;
  }

  .oh-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    flex: 1;
  }
  .oh-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.625rem 0;
    border-bottom: 1px solid var(--color-border);
    font-size: var(--font-size-sm);
  }
  .oh-row:last-child {
    border-bottom: none;
  }
  .oh-row--today {
    background: rgba(61, 186, 167, 0.07);
    margin-inline: -0.75rem;
    padding-inline: 0.75rem;
    border-radius: 0.5rem;
    border-bottom: none;
    font-weight: 600;
  }
  .oh-row--today .oh-time {
    color: var(--color-secondary-dark);
  }
  .oh-row--closed .oh-day,
  .oh-row--closed .oh-time {
    color: var(--color-text-muted);
    opacity: 0.5;
  }
  .oh-day {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text);
  }
  .oh-today-tag {
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--color-secondary);
    color: #fff;
    padding: 0.15rem 0.5rem;
    border-radius: 9999px;
  }
  .oh-time {
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .oh-note {
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
    font-size: 0.78rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
  }
  .oh-note svg {
    flex-shrink: 0;
    margin-top: 0.1rem;
    color: var(--color-warning);
  }
  .oh-note a {
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
  }
  .oh-note a:hover {
    text-decoration: underline;
  }
  @media (prefers-reduced-motion: reduce) {
    .oh-dot {
      animation: none;
    }
  }
</style>
