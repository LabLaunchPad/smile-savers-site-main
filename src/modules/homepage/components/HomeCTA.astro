---
import { siteConfig } from '@/config/site';
---

<section class="hcta" aria-labelledby="cta-heading">

  <div class="hcta-bg" aria-hidden="true">
    <div class="hcta-glow hcta-glow-1"></div>
    <div class="hcta-glow hcta-glow-2"></div>
    <div class="hcta-grid"></div>
  </div>

  <div class="hcta-inner">

    <!-- Left: main CTA -->
    <div class="hcta-left">
      <span class="hcta-pill">
        <span class="hcta-pill-dot" aria-hidden="true"></span>
        Accepting New Patients Today
      </span>
      <h2 id="cta-heading" class="hcta-h2">Ready for a Healthier Smile?</h2>
      <p class="hcta-desc">
        Schedule your appointment online in minutes. Our team will confirm within 24 hours.
        New patients always welcome.
      </p>
      <div class="hcta-actions">
        <a href="tel:+17189568400" class="hcta-btn-primary">
          Call Now
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <div class="hcta-phone-wrap">
          <span class="hcta-phone-label">Or call us directly</span>
          <a href="tel:+17189568400" class="hcta-phone">(718) 956-8400</a>
        </div>
      </div>
      <p class="hcta-micro">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        Most patients are booked within 24 hours &middot;
        <a href="/contact" class="hcta-emergency">Emergency? Call now ›</a>
      </p>
    </div>

    <!-- Right: info cards -->
    <div class="hcta-right">

      <div class="info-card">
        <div class="info-card-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <div>
          <h3 class="info-card-title">Visit Us</h3>
          <address class="info-card-body">
            3202 53rd Place<br/>
            Woodside, NY 11377
          </address>
          <a
            href="https://maps.google.com/?q=3202+53rd+Pl,+Woodside,+NY+11377"
            target="_blank"
            rel="noopener noreferrer"
            class="info-card-link"
          >
            Get Directions
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        </div>
      </div>

      <div class="info-card">
        <div class="info-card-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </div>
        <div>
          <h3 class="info-card-title">Office Hours</h3>
          <dl class="hours-list">
            {
              siteConfig.hours.map((h) => {
                const daysLabel = h.days.length > 1
                  ? `${h.days[0].slice(0, 3)} – ${h.days[h.days.length - 1].slice(0, 3)}`
                  : h.days[0];
                const isClosed = h.open === 'Closed';
                const isSaturday = (h.days as readonly string[]).includes('Saturday');
                const isSunday = (h.days as readonly string[]).includes('Sunday');
                return (
                  <div class={`hours-row ${isSaturday ? 'hours-row-highlight' : ''} ${isClosed || isSunday ? 'hours-row-muted' : ''}`}>
                    <dt>{daysLabel}</dt>
                    <dd>{h.display}</dd>
                  </div>
                );
              })
            }
          </dl>
        </div>
      </div>

    </div>

  </div>
</section>

<style>
@keyframes hcta-dot-pulse{0%,100%{opacity:1}50%{opacity:.3}}

.hcta{
  position:relative;
  background:var(--color-primary);
  overflow:hidden;
  padding:clamp(3.5rem,6vw,6rem) 0;
}
.hcta-bg{position:absolute;inset:0;pointer-events:none}
.hcta-glow{position:absolute;border-radius:50%;filter:blur(80px)}
.hcta-glow-1{width:40rem;height:40rem;top:-10rem;left:-8rem;background:radial-gradient(circle,rgba(61,186,167,.15),transparent 70%)}
.hcta-glow-2{width:32rem;height:32rem;bottom:-8rem;right:-4rem;background:radial-gradient(circle,rgba(44,171,223,.12),transparent 70%)}
.hcta-grid{
  position:absolute;inset:0;
  background-image:linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);
  background-size:48px 48px;
}

.hcta-inner{
  position:relative;
  max-width:var(--container-xl);
  margin-inline:auto;
  padding-inline:var(--spacing-element);
  display:grid;
  grid-template-columns:1fr;
  gap:clamp(2.5rem,4vw,4rem);
}
@media(min-width:1024px){.hcta-inner{grid-template-columns:1.4fr 1fr;align-items:center}}
@media(max-width:639px){.hcta-inner{padding-inline:.75rem}}

.hcta-pill{
  display:inline-flex;align-items:center;gap:.5rem;
  font-size:.7rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;
  color:rgba(61,186,167,.9);
  background:rgba(61,186,167,.1);
  border:1px solid rgba(61,186,167,.25);
  padding:.35rem 1rem;border-radius:9999px;
  margin-bottom:1.25rem;
}
.hcta-pill-dot{
  width:.45rem;height:.45rem;border-radius:50%;background:var(--color-secondary);
  animation:hcta-dot-pulse 2s ease-in-out infinite;
}
.hcta-h2{
  font-size:clamp(2rem,4vw,3rem);
  font-family:var(--font-family-heading);
  font-weight:700;
  color:#fff;
  letter-spacing:-.025em;
  line-height:1.1;
  margin:0 0 1.25rem;
}
.hcta-desc{
  font-size:var(--font-size-lg);
  color:rgba(255,255,255,.7);
  line-height:1.7;
  margin:0 0 2rem;
  max-width:38rem;
}
.hcta-actions{
  display:flex;
  flex-direction:column;
  gap:1.25rem;
  margin-bottom:1.5rem;
}
@media(min-width:480px){.hcta-actions{flex-direction:row;align-items:center}}

.hcta-btn-primary{
  display:inline-flex;align-items:center;gap:.5rem;
  padding:.9rem 1.75rem;
  border-radius:.75rem;
  background:var(--color-accent);
  color:#fff;
  font-weight:700;font-size:1rem;
  text-decoration:none;
  box-shadow:0 8px 28px rgba(44,171,223,.4);
  transition:all .25s ease;
  white-space:nowrap;
}
.hcta-btn-primary:hover{background:var(--color-accent-dark);transform:translateY(-2px);box-shadow:0 14px 38px rgba(44,171,223,.55)}

.hcta-phone-wrap{
  display:flex;flex-direction:column;gap:.125rem;
}
@media(min-width:480px){
  .hcta-phone-wrap{
    padding-left:1.25rem;
    border-left:1px solid rgba(255,255,255,.15);
  }
}
.hcta-phone-label{font-size:.72rem;color:rgba(255,255,255,.5)}
.hcta-phone{
  font-size:var(--font-size-lg);font-weight:700;
  color:#fff;text-decoration:none;
  transition:color .2s;
}
.hcta-phone:hover{color:var(--color-secondary)}

.hcta-micro{
  display:flex;align-items:center;gap:.375rem;flex-wrap:wrap;
  font-size:.8rem;
  color:rgba(255,255,255,.45);
  margin:0;
}
.hcta-micro svg{flex-shrink:0;color:var(--color-secondary)}
.hcta-emergency{
  color:#FFC107;
  font-weight:600;
  text-decoration:none;
}
.hcta-emergency:hover{text-decoration:underline}

/* Info cards */
.hcta-right{display:grid;grid-template-columns:1fr;gap:1rem}
@media(min-width:480px) and (max-width:1023px){.hcta-right{grid-template-columns:repeat(2,1fr)}}

.info-card{
  display:flex;gap:1rem;
  padding:1.5rem;
  background:rgba(255,255,255,.07);
  border:1px solid rgba(255,255,255,.12);
  border-radius:1.125rem;
  backdrop-filter:blur(12px);
  transition:all .25s ease;
}
.info-card:hover{
  background:rgba(255,255,255,.12);
  border-color:rgba(255,255,255,.2);
}
.info-card-icon{
  width:2.5rem;height:2.5rem;
  border-radius:.625rem;
  background:rgba(61,186,167,.2);
  color:var(--color-secondary);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
}
.info-card-title{
  font-size:var(--font-size-sm);
  font-weight:700;
  color:#fff;
  margin:0 0 .5rem;
}
.info-card-body{
  font-style:normal;
  font-size:var(--font-size-sm);
  color:rgba(255,255,255,.6);
  line-height:1.7;
  margin:0 0 .625rem;
}
.info-card-link{
  display:inline-flex;align-items:center;gap:.375rem;
  font-size:.78rem;font-weight:600;
  color:var(--color-secondary);text-decoration:none;
  transition:gap .2s;
}
.info-card-link:hover{gap:.625rem;text-decoration:underline}

.hours-list{margin:0}
.hours-row{
  display:flex;justify-content:space-between;gap:.75rem;
  font-size:.8rem;
  padding:.25rem 0;
  border-bottom:1px solid rgba(255,255,255,.06);
}
.hours-row:last-child{border-bottom:none}
.hours-row dt{color:rgba(255,255,255,.5)}
.hours-row dd{margin:0;font-weight:600;color:rgba(255,255,255,.85)}
.hours-row-highlight dd{color:var(--color-secondary)}
.hours-row-muted dt,.hours-row-muted dd{color:rgba(255,255,255,.3)}
</style>
